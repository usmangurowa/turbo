{
  "name": "@turbo/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo node_modules .build",
    "dev": "pnpm with-env npx expo start --clear",
    "dev:android": "pnpm with-env expo start --android --clear",
    "dev:ios": "pnpm with-env expo start --ios --clear",
    "android": "pnpm with-env expo run:android",
    "ios": "pnpm with-env expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "build:ios:dev": "pnpm with-env npx eas build --profile development-simulator-local --platform ios --local --output .build/ios-dev-simulator.tar.gz && cd .build && tar -xzf ios-dev-simulator.tar.gz && rm ios-dev-simulator.tar.gz && xcrun simctl install booted $(find . -maxdepth 1 -name '*.app' -type d | head -1)",
    "build:ios:prev": "pnpm with-env npx eas build --profile preview-simulator-local --platform ios --local --output .build/ios-preview-simulator.tar.gz && cd .build && tar -xzf ios-preview-simulator.tar.gz && rm ios-preview-simulator.tar.gz && xcrun simctl install booted $(find . -maxdepth 1 -name '*.app' -type d | head -1)",
    "build:android:dev": "pnpm with-env npx eas build --profile development-android-local --platform android --local --output .build/android-dev.apk",
    "build:android:prev": "pnpm with-env npx eas build --profile preview-android-local --platform android --local --output .build/android-preview.apk",
    "ios:install": "xcrun simctl install booted .build/TurboDev.app",
    "android:install:dev": "adb install -r .build/android-dev.apk",
    "android:install:prev": "adb install -r .build/android-preview.apk"
  },
  "dependencies": {
    "@better-auth/expo": "catalog:",
    "@expo/dom-webview": "56.0.5",
    "@expo/metro-runtime": "56.0.13",
    "@gorhom/bottom-sheet": "^5.2.14",
