# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your Supabase database.
POSTGRES_URL=''
PORT='3001'
SERVER_URL='http://localhost:3001'
APP_URL='http://localhost:3000'
NEXT_PUBLIC_PORT='3000'
NEXT_PUBLIC_APP_URL='http://localhost:3000'


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET=''
AUTH_REDIRECT_PROXY_URL=''
GITHUB_CLIENT_ID=''
GITHUB_CLIENT_SECRET=''


# Supabase Configuration
# @see https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=''
NEXT_PUBLIC_SUPABASE_ANON_KEY=''
EXPO_PUBLIC_SUPABASE_URL=''
EXPO_PUBLIC_SUPABASE_ANON_KEY=''
SUPABASE_JWT_SECRET=''

# Resend Configuration (for email sending)
RESEND_API_KEY=''

# EAS (Expo Application Services) Configuration
# Get your project ID from: https://expo.dev/accounts/[username]/projects/[project]
EAS_PROJECT_ID='your-eas-project-id'
EXPO_OWNER='your-expo-username'

# Expo App Configuration
EXPO_PUBLIC_APP_NAME='MyApp'
EXPO_PUBLIC_APP_SLUG='myapp'
EXPO_PUBLIC_APP_SCHEME='myapp'
EXPO_PUBLIC_PACKAGE_NAME='com.mycompany.myapp'
EXPO_PUBLIC_API_URL='http://localhost:3000'


# PostHog Analytics
# Get your API key from: https://posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=''
NEXT_PUBLIC_POSTHOG_HOST='https://us.i.posthog.com'
# For server-side
POSTHOG_API_KEY=''
POSTHOG_HOST='https://us.i.posthog.com'
# For mobile app
EXPO_PUBLIC_POSTHOG_KEY=''
EXPO_PUBLIC_POSTHOG_HOST='https://us.i.posthog.com'

# Sentry Error Tracking
SENTRY_DSN=''
NEXT_PUBLIC_SENTRY_DSN=''
EXPO_PUBLIC_SENTRY_DSN=''

# Trigger.dev Background Jobs
TRIGGER_SECRET_KEY=''
TRIGGER_PROJECT_ID=''

# AI Providers
GEMINI_API_KEY=''
GOOGLE_GENERATIVE_AI_API_KEY=''
OPENROUTER_API_KEY=''
GROQ_API_KEY=''
