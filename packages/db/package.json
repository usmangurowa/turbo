{
  "name": "@turbo/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "generate": "node ./scripts/drizzle.mjs generate",
    "lint": "eslint",
    "migrate": "node ./scripts/drizzle.mjs migrate",
    "push:local": "node ./scripts/drizzle.mjs push",
    "studio": "node ./scripts/drizzle.mjs studio",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@turbo/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@turbo/eslint-config": "workspace:*",
    "@turbo/prettier-config": "workspace:*",
    "@turbo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.10"
  },
  "prettier": "@turbo/prettier-config"
}
